# Copy to .env and fill in values. Never commit .env.
#   cp .env.example .env

# OpenAI — GPT-4o explanations in Next.js API routes
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Modal — local SDK calls to deployed run_tribe (https://modal.com/settings)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# YouTube Data API — public video metadata (optional; reference corpus)
YOUTUBE_API_KEY=

# Hugging Face — gated models (Llama). Usually stored as Modal secret
# "huggingface-token" for GPU runs; only needed locally for image builds.
HF_TOKEN=
